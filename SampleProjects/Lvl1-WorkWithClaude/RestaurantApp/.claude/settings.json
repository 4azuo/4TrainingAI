{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "Cấu hình DÙNG CHUNG cho cả team — commit vào git. Không để secret ở đây.",

  "model": "claude-opus-4-8",
  "cleanupPeriodDays": 30,

  "env": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1",
    "RESTAURANTAPP_ENV": "development"
  },

  "permissions": {
    "//": "allow = chạy không cần hỏi; ask = hỏi trước; deny = chặn tuyệt đối",
    "allow": [
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./docs/**)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet format:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(dotnet publish:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pfx)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ]
  },

  "hooks": {
    "//": "PostToolUse: tự format file C# sau mỗi lần Claude sửa code",
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ./.claude/hooks/format-on-save.ps1"
          }
        ]
      }
    ],
    "//pretooluse": "PreToolUse: chặn ghi vào vùng cấm trước khi thao tác xảy ra",
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ./.claude/hooks/protect-paths.ps1"
          }
        ]
      }
    ]
  }
}
